# === Supabase ===
# Los encontrás en Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# URL pública de la app (en local dejá esto; en Vercel poné la URL real)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Cron Jobs (REQUERIDO en Vercel para que funcionen los automáticos) ===
# Generá un string random seguro y pegalo en Vercel > Project > Settings > Environment Variables
# En local no hace falta (los crones no corren localmente).
# CRON_SECRET=

# === Email (OPCIONAL - notificaciones por mail) ===
# Si no lo configurás, la app igual funciona con notificaciones in-app.
# RESEND_API_KEY=

# === Gmail (OPCIONAL - traer CVs al reclutamiento desde la casilla de la agencia) ===
# Reusa el MISMO GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET que ya usa Calendar.
# Hay que habilitar la Gmail API en el proyecto de Google Cloud y agregar el scope
# gmail.readonly + este redirect URI en la pantalla de consentimiento (ver
# docs/gmail-cv-setup.md). Default: {NEXT_PUBLIC_SITE_URL}/api/gmail/callback
# GMAIL_REDIRECT_URI=

# === TikTok (OPCIONAL - resultados orgánicos por cuenta) ===
# Mientras no estén seteadas, la conexión de TikTok ni aparece en la app.
# Se obtienen creando una app en https://developers.tiktok.com (ver docs/tiktok-setup.md).
# El redirect URI por defecto es {NEXT_PUBLIC_SITE_URL}/api/tiktok/callback
# (registralo igual en la app de TikTok).
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=   # opcional, solo si querés forzar una distinta a la default
